# MangaZap Environment Variables
# Copy this file to .env and fill in the values

# Signing key for template integrity signatures
MANGAZAP_SIGNING_KEY=change-this-in-production

# MiMo API configuration (for text/chat generation)
MIMO_API_BASE=https://api.mimo.com/v1
MIMO_API_KEY=
MIMO_MODEL=mimo-v2.5

# Image generation API
IMAGE_API_PROVIDER=agnes
AGNES_API_KEY=
REPLICATE_API_TOKEN=
STABILITY_API_KEY=

# CORS allowed origins (comma-separated)
MANGAZAP_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Data storage paths
MANGAZAP_PROJECTS_DIR=D:/mangazap_data/projects
MANGAZAP_IMAGES_DIR=D:/mangazap_data/images
